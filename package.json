{
  "name": "audible-hero",
  "description": "Series",
  "version": "1.0.0",
  "author": "Eirik Brandtzæg <eirikb@eirikb.no>",
  "private": true,
  "scripts": {
    "dev": "parcel src/main.js --https --port 8080 --hmr-hostname localhost",
    "build": "parcel build src/main.js --no-source-maps",
    "ext": "shx rm -rf dist audiblehero.zip && shx mkdir -p dist && shx cp -r ext/* dist/",
    "zip": "cd dist; zip ../audiblehero.zip *",
    "prod": "npm-run-all ext build zip",
    "start": "npm-run-all ext dev"
  },
  "dependencies": {
    "@eirikb/domdom": "1.2.1",
    "@material/button": "^3.2.0",
    "lz-string": "1.4.4"
  },
  "devDependencies": {
    "parcel": "1.12.3",
    "sass": "1.22.12",
    "shx": "0.3.2",
    "npm-run-all": "4.1.5"
  }
}
